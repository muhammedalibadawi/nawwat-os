# Database (default: sqlite in current dir)
# DATABASE_URL=sqlite:///./nawwat.db
# DATABASE_URL=postgresql://user:pass@localhost/nawwat

# Environment: development | production
# ENV=development

# Comma-separated allowed CORS origins (production: set to your frontend URL)
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Secret key for JWT/sessions (change in production)
# SECRET_KEY=change-me-in-production

# Disable master admin bypass in production
# MASTER_ADMIN_BYPASS_ENABLED=false
